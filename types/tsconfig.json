{
	"compilerOptions": {
		"incremental": true,
		"composite": true,
		"target": "es2020",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"declaration": true,
		"emitDeclarationOnly": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"allowImportingTsExtensions": true
	},
	"include": ["littlebook.ts", "brand.ts"]
}
