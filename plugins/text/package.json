{
	"name": "@littlebook/text",
	"description": "a littlebook content plugin providing a text editor",
	"version": "1.0.0",
	"type": "module",
	"main": "output/text.js",
	"littlebook": {
		"contentViews": [
			{
				"identifier": "text-editor",
				"displayName": "codemirror",
				"contentTypes": [
					"public.plain-text",
					"public.python-script",
					"net.daringfireball.markdown",
					"com.netscape.javascript-source"
				]
			}
		]
	},
	"scripts": {
		"mk": "NODE_ENV=production node mk",
		"w": "node mk/w",
		"dev": "NODE_ENV=development node mk/w",
		"test": "echo \"Error: no test specified\" && exit 1"
	},
	"keywords": [],
	"author": "chee",
	"license": "AGPL-3.0+",
	"dependencies": {
		"@automerge/automerge": "^2.2.4",
		"@automerge/automerge-codemirror": "^0.0.11",
		"@codemirror/lang-html": "^6.4.9",
		"@codemirror/lang-javascript": "^6.2.2",
		"@codemirror/lang-markdown": "^6.2.5",
		"@codemirror/lang-python": "^6.1.6",
		"@codemirror/language": "^6.10.2",
		"@codemirror/state": "^6.4.1",
		"@codemirror/view": "^6.28.2",
		"codemirror": "^6.0.1"
	},
	"devDependencies": {
		"@types/node": "^20.14.10",
		"esbuild": "^0.21.5"
	}
}
