{
	"compilerOptions": {
		"allowImportingTsExtensions": true,
		"target": "ES2020",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"noEmit": true,
		"checkJs": true,
		"strict": true,
		"allowJs": true,
		/* Preact Config */
		"jsx": "react-jsx",
		"jsxImportSource": "preact",
		"skipLibCheck": true,
		"paths": {
			"react": ["./node_modules/preact/compat/"],
			"react-dom": ["./node_modules/preact/compat/"]
		}
	},
	"include": ["*.ts", "*.tsx", "create-custom-element.js"]
}
